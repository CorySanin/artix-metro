{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "type": "node",
            "request": "launch",
            "name": "Launch Program",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "env": {
                "GPGPASS": "${input:gpgpass}"
            },
            "program": "${workspaceFolder}/distribution/src/artix-metro.js",
            "preLaunchTask": "tsc: build - tsconfig.json",
            "args": [
                "add",
                "stable",
                "telegram-desktop"
            ],
            "sourceMaps": true,
            "outFiles": [
                "${workspaceFolder}/distribution/**/*.js"
            ]
        }
    ],
    "inputs": [
    {
      "id": "gpgpass",
      "type": "promptString",
      "description": "Enter your GPG password"
    }
  ]
}