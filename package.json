{
  "name": "artix-metro",
  "version": "3.1.17",
  "description": "Automate pushing packages to Artix",
  "keywords": [
    "artix",
    "artixlinux"
  ],
  "homepage": "https://gitea.artixlinux.org/corysanin/artix-metro",
  "bugs": {
    "url": "https://github.com/CorySanin/artix-metro/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://gitea.artixlinux.org/corysanin/artix-metro.git"
  },
  "license": "MIT",
  "author": {
    "name": "Cory Sanin",
    "email": "corysanin@artixlinux.org",
    "url": "https://sanin.dev/"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./distribution/src/index.d.ts",
      "import": "./distribution/src/index.js"
    }
  },
  "main": "./distribution/src/index.js",
  "types": "./distribution/src/index.d.ts",
  "bin": {
    "artix-metro": "./distribution/src/artix-metro.js"
  },
  "files": [
    "distribution",
    "completion"
  ],
  "scripts": {
    "build": "npx tsc && rm ./distribution/src/*.map && chmod +x ./distribution/src/artix-metro.js",
    "clean": "rm -rf ./distribution",
    "watch": "npx tsc -w"
  },
  "dependencies": {
    "artix-checkupdates": "1.2.0",
    "cli-color": "2.0.4",
    "glob": "13.0.6",
    "json5": "2.2.3",
    "ky": "1.14.3",
    "spawn-but-with-promises": "^1.0.4"
  },
  "devDependencies": {
    "@sindresorhus/tsconfig": "8.1.0",
    "@types/cli-color": "2.0.6",
    "@types/node": "25.5.0",
    "typescript": "6.0.2"
  }
}
